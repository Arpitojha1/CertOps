# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# --- Auth ---
# Secret key for signing JWT tokens. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-256-bit-hex-string
JWT_EXPIRE_HOURS=24
# Used by src/seed_admin.py to create the first admin account. Never committed.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
# Set to "true" in production (HTTPS only)
COOKIE_SECURE=false

# --- Credential Encryption at Rest ---
# 32-byte urlsafe base64-encoded Fernet key used to encrypt sensitive connector credentials at rest in SQLite.
# Generate once and persist in .env: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CERTOPS_CONFIG_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY_DO_NOT_USE_UNCHANGED

# --- CORS ---
# Comma-separated list of allowed origins. Never use * with credentials.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- API server ---
API_PORT=8000

# --- HashiCorp Vault (dev mode) ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root
VAULT_CERT_PATH=secret/local-certs
# --- Azure ---
AZURE_TENANT_ID="<Your Directory tenant ID>"
AZURE_CLIENT_ID="<Your Application client ID>"
AZURE_CLIENT_SECRET="<The secret value you copied>"
AZURE_KEYVAULT_URL="https://<your-vault-name>.vault.azure.net/"
# --- step-ca ---
# Path to the CA's password file (used with --password-file, not typed interactively)
STEP_CA_PASSWORD_FILE=./pass.txt
# Base URL of the running step-ca instance
STEP_CA_URL=https://localhost:9000
# Fingerprint of the step-ca root cert, needed by step CLI/SDK calls to trust it
STEP_CA_FINGERPRINT=

# --- Nginx / deployment target ---
NGINX_CONTAINER_NAME=certops-nginx-1
# Host filesystem paths Nginx's volume mount points at (Windows path, not container path)
DEPLOY_CERT_PATH=./local.crt
DEPLOY_KEY_PATH=./local.key

# --- Renewal policy ---
RENEWAL_THRESHOLD_DAYS=2
# Per-connector overrides (authoritative over global RENEWAL_THRESHOLD_DAYS):
# For short-lived CAs like step-ca (24h validity), set threshold to 0.25 days (6 hours):
STEP_CA_RENEWAL_THRESHOLD_DAYS=0.25

# --- Verification target ---
VERIFY_HOST=localhost
VERIFY_PORT=443

# --- Host Connector (SSH / Linux / Nginx) ---
ENABLE_SSH_HOST=false
SSH_HOST=localhost
SSH_PORT=2222
SSH_USERNAME=root
# Password or key file path for SSH authentication (never commit real passwords)
SSH_PASSWORD=certops
# SSH_KEY_FILE=
SSH_NGINX_CONF_DIR=/etc/nginx/conf.d

# --- Host Connector (WinRM / Windows / IIS) ---
ENABLE_WINRM_HOST=false
WINRM_HOST=localhost
WINRM_PORT=5985
WINRM_USERNAME=Administrator
WINRM_PASSWORD=
WINRM_AUTH_TYPE=ntlm
WINRM_IIS_SITE_NAME=Default Web Site
